# ==================================
# VendHub API - Environment Variables
# ==================================

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database (PostgreSQL 16 via Supabase)
# Project: gwrfhzvulvkudobtmkrs | Region: ap-southeast-1 (Singapore)
# Transaction pooler — required for NestJS/TypeORM (stateless connections)
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.gwrfhzvulvkudobtmkrs
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
DB_SYNCHRONIZE=false
DB_SSL=true
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_LOGGING=false
DB_MIGRATIONS_RUN=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cookie
COOKIE_SECRET=

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=VendHub API
SWAGGER_VERSION=1.0.0

# API URL (for Swagger server)
API_URL=http://localhost:4000

# Trust Proxy
TRUST_PROXY=1

# Body size limit
MAX_BODY_SIZE=10mb

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_DEV_ENABLED=false

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# SMS Providers
ESKIZ_BASE_URL=https://notify.eskiz.uz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
PLAYMOBILE_BASE_URL=https://send.smsaero.uz
PLAYMOBILE_LOGIN=
PLAYMOBILE_PASSWORD=

# Storage (Supabase Storage — S3-compatible API)
# Keys: Supabase Dashboard → Storage → S3 Access Keys
S3_ENDPOINT=https://gwrfhzvulvkudobtmkrs.supabase.co/storage/v1/s3
S3_ACCESS_KEY=YOUR_SUPABASE_STORAGE_ACCESS_KEY
S3_SECRET_KEY=YOUR_SUPABASE_STORAGE_SECRET_KEY
S3_BUCKET=vendhub
S3_REGION=ap-southeast-1
S3_CDN_URL=https://gwrfhzvulvkudobtmkrs.supabase.co/storage/v1/object/public/vendhub

# Payment Providers
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
UZUM_TERMINAL_ID=
UZUM_CASH_ID=

# Fiscal Integration (OFD/Soliq)
FISCAL_BASE_URL=
FISCAL_INN=
FISCAL_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vendhub.uz

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Feature Flags
ENABLE_METRICS=true
ENABLE_SWAGGER=true
