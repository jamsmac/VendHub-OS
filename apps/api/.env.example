# ==================================
# VendHub API - Environment Variables
# ==================================

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database (PostgreSQL 16)
# Option 1: Single connection string (Supabase, Railway, Neon)
# DATABASE_URL=postgresql://user:password@host:port/database
#
# Option 2: Individual vars (traditional, for Docker Compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendhub
DB_USER=vendhub
DB_PASSWORD=
DB_SYNCHRONIZE=false
DB_SSL=false
DB_POOL_SIZE=10
DB_LOGGING=false
DB_MIGRATIONS_RUN=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cookie
COOKIE_SECRET=

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=VendHub API
SWAGGER_VERSION=1.0.0

# API URL (for Swagger server)
API_URL=http://localhost:4000

# Trust Proxy
TRUST_PROXY=1

# Body size limit
MAX_BODY_SIZE=10mb

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_DEV_ENABLED=false

# Rate Limiting (max requests per 60s window)
THROTTLE_LIMIT=100

# SMS Providers (Uzbekistan)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# ESKIZ_SENDER_ID=4546
# PLAYMOBILE_LOGIN=
# PLAYMOBILE_PASSWORD=
# PLAYMOBILE_SENDER_ID=

# Storage (S3-compatible: MinIO, Supabase Storage, AWS S3)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=vendhub
STORAGE_REGION=us-east-1
# STORAGE_PUBLIC_URL=
# STORAGE_FORCE_PATH_STYLE=true

# Payment Providers (Uzbekistan)
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
# PAYME_BASE_URL=https://checkout.paycom.uz/api
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
# CLICK_BASE_URL=https://my.click.uz/services/pay
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
# UZUM_API_URL=https://api.uzum.uz

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vendhub.uz

# Logging
LOG_LEVEL=debug

# 2FA Encryption Key (AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Feature Flags
# ENABLE_METRICS=true
