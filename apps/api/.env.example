# ==================================
# VendHub API - Environment Variables
# ==================================

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database (PostgreSQL 16)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendhub
DB_USER=vendhub
DB_PASSWORD=
DB_SYNCHRONIZE=false
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cookie
COOKIE_SECRET=

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=VendHub API
SWAGGER_VERSION=1.0.0

# API URL (for Swagger server)
API_URL=http://localhost:4000

# Trust Proxy
TRUST_PROXY=1

# Body size limit
MAX_BODY_SIZE=10mb

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_DEV_ENABLED=false

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# SMS Providers
ESKIZ_BASE_URL=https://notify.eskiz.uz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
PLAYMOBILE_BASE_URL=https://send.smsaero.uz
PLAYMOBILE_LOGIN=
PLAYMOBILE_PASSWORD=

# Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vendhub
S3_REGION=us-east-1
S3_CDN_URL=

# Payment Providers
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
UZUM_TERMINAL_ID=
UZUM_CASH_ID=

# Fiscal Integration (OFD/Soliq)
FISCAL_BASE_URL=
FISCAL_INN=
FISCAL_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vendhub.uz

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
