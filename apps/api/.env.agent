# Agent Mode Configuration
# Start API with: AGENT_MODE=true pnpm --filter api dev
# Or: cp .env.agent .env && pnpm --filter api dev

AGENT_MODE=true

# Fake user injected into every request (no JWT needed)
AGENT_USER_EMAIL=agent@vendhub.test
AGENT_USER_ROLE=owner
AGENT_ORG_ID=00000000-0000-0000-0000-000000000001

# Minimal config for local development
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database (docker-compose defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendhub
DB_USER=vendhub
DB_PASSWORD=vendhub_password

# Redis (docker-compose defaults)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth (any value, agent mode bypasses JWT)
JWT_SECRET=agent-mode-secret
JWT_REFRESH_SECRET=agent-mode-refresh-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# Disable Sentry in agent mode
# SENTRY_DSN=

# Swagger always on
SWAGGER_ENABLED=true
