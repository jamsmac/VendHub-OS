# VendHub Mobile App Environment Variables
# Copy to .env and fill in values

# API URL (overrides app.config.ts extra.apiUrl)
# For local dev: http://localhost:4000
# For production: https://vendhubapi-production.up.railway.app
EXPO_PUBLIC_API_URL=http://localhost:4000

# App mode: client | staff
EXPO_PUBLIC_DEFAULT_MODE=client
