# ==================================
# VendHub Telegram Bot - Environment Variables
# ==================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# API
API_URL=http://localhost:4000
BOT_API_TOKEN=  # JWT token for bot service account (generate via admin panel or CLI)

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# App Mode
BOT_MODE=polling
NODE_ENV=development
