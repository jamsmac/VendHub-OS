# ==================================
# VendHub Telegram Bot - Environment Variables
# ==================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=
WEBHOOK_DOMAIN=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=  # Required in production — validates incoming Telegram webhook requests

# API
API_URL=http://localhost:4000
BOT_API_TOKEN=  # JWT token for bot service account (generate via admin panel or CLI)

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# App Mode
BOT_MODE=polling
NODE_ENV=development
