# ==================================================
# VendHub Client (Telegram Mini App) - Production Dockerfile
# Vite + React with nginx
# ==================================================

# Stage 1: Dependencies
FROM node:20-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# Copy workspace files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/client/package.json ./apps/client/
COPY packages/shared/package.json ./packages/shared/

# Install dependencies
RUN pnpm install --frozen-lockfile

# ==================================================
# Stage 2: Development (for docker-compose dev mode)
FROM node:20-alpine AS development
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/client/package.json ./apps/client/
COPY packages/shared/package.json ./packages/shared/

RUN pnpm install

COPY . .

# Build shared package (client imports from @vendhub/shared)
RUN pnpm --filter @vendhub/shared build

EXPOSE 5173

CMD ["pnpm", "--filter", "@vendhub/client", "dev", "--host"]

# ==================================================
# Stage 3: Builder
FROM node:20-alpine AS builder
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# Copy deps
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/client/node_modules ./apps/client/node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules

# Copy source
COPY apps/client ./apps/client
COPY packages ./packages
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* tsconfig.base.json ./

# Build shared package first (client imports from @vendhub/shared)
RUN pnpm --filter @vendhub/shared build

# Build environment
ENV NODE_ENV=production

# Build arguments for environment variables
ARG VITE_API_URL
ARG VITE_TELEGRAM_BOT_NAME
ARG VITE_APP_ENV=production

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_TELEGRAM_BOT_NAME=$VITE_TELEGRAM_BOT_NAME
ENV VITE_APP_ENV=$VITE_APP_ENV

# Build
RUN pnpm --filter @vendhub/client build

# ==================================================
# Stage 4: Production Runner (MUST be last for Railway)
FROM nginx:alpine AS production

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy custom nginx config as template (envsubst replaces $PORT at runtime)
COPY apps/client/nginx.conf /etc/nginx/templates/default.conf.template

# Copy built assets
COPY --from=builder /app/apps/client/dist /usr/share/nginx/html

# Configure nginx to run as non-root (templates dir must be readable for envsubst)
RUN chown -R nginx:nginx /var/cache/nginx /var/log/nginx /etc/nginx/conf.d /etc/nginx/templates && \
    touch /var/run/nginx.pid && \
    chown nginx:nginx /var/run/nginx.pid

# Default port (Railway overrides via $PORT)
ENV PORT=80

# Add health check script (uses $PORT at runtime)
RUN echo '#!/bin/sh' > /docker-healthcheck.sh && \
    echo 'wget --no-verbose --tries=1 --spider http://localhost:${PORT}/health || exit 1' >> /docker-healthcheck.sh && \
    chmod +x /docker-healthcheck.sh

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD /docker-healthcheck.sh

# Run as non-root nginx user
USER nginx

EXPOSE 80

# nginx entrypoint auto-processes /etc/nginx/templates/*.template via envsubst
CMD ["nginx", "-g", "daemon off;"]
