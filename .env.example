# ============================================================================
# VendHub OS Environment Variables
# Copy to .env and fill in your values
# ============================================================================

# ============================================================================
# GENERAL
# ============================================================================
NODE_ENV=development
# NODE_ENV=production
APP_NAME=VendHub
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
HOST=0.0.0.0

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
# Option 1: Single connection string (Supabase, Railway, Neon)
# DATABASE_URL=postgresql://user:password@host:port/database
#
# Option 2: Individual vars (traditional, for Docker Compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendhub
DB_USER=vendhub
DB_PASSWORD=vendhub_secret
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_POOL_SIZE=10
DB_SSL=false
# Set to 'false' for Supabase shared (uses pooler certificate)
DB_SSL_REJECT_UNAUTHORIZED=true
# Auto-run migrations on app start (recommended for Railway)
DB_MIGRATIONS_RUN=false
# Slow query threshold in milliseconds (logged as warning)
# DB_SLOW_QUERY_THRESHOLD=1000

# ============================================================================
# REDIS
# ============================================================================
# Option 1: Single URL (Upstash, Railway Redis)
# REDIS_URL=rediss://default:password@host:port
#
# Option 2: Individual vars (Docker Compose)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_generate_strong_password
#
# Cache TTL in seconds (default: 300 = 5 min)
CACHE_TTL=300
#
# Note: If neither REDIS_URL nor REDIS_HOST is set, caching falls back
# to in-memory. BullMQ queues still require Redis for background jobs.

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate with: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long_here
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here_also_32_chars
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# 2FA (TOTP)
# ============================================================================
TOTP_ISSUER=VendHub
TOTP_ALGORITHM=sha1
TOTP_DIGITS=6
TOTP_PERIOD=30

# AES-256 key for encrypting TOTP secrets at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================================================
# API SETTINGS
# ============================================================================
API_PORT=4000
API_PREFIX=api/v1
# Comma-separated list of allowed origins
# Production: https://vendhubweb-production.up.railway.app,https://vendhubclient-production.up.railway.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=1
MAX_BODY_SIZE=10mb

# ============================================================================
# COOKIES
# ============================================================================
# Generate with: openssl rand -base64 32
COOKIE_SECRET=your_cookie_signing_secret_here
COOKIE_DOMAIN=
# Options: strict, lax, none (use 'none' only with COOKIE_SECURE=true for cross-site)
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
COOKIE_PATH=/
# Session duration in days
# SESSION_DAYS=30

# ============================================================================
# WEB & CLIENT PORTS
# ============================================================================
WEB_PORT=3000
CLIENT_PORT=5173

# ============================================================================
# SWAGGER API DOCS
# ============================================================================
# Disabled by default in production. Set to 'true' to enable.
SWAGGER_ENABLED=true
SWAGGER_TITLE=VendHub API
SWAGGER_VERSION=1.0.0

# ============================================================================
# PASSWORD POLICY
# ============================================================================
# PASSWORD_MIN_LENGTH=8
# PASSWORD_MAX_LENGTH=128
# PASSWORD_REQUIRE_UPPERCASE=true
# PASSWORD_REQUIRE_LOWERCASE=true
# PASSWORD_REQUIRE_NUMBERS=true
# PASSWORD_REQUIRE_SPECIAL_CHARS=false
# PASSWORD_MIN_UNIQUE_CHARS=4
# PASSWORD_PREVENT_COMMON=true
# PASSWORD_PREVENT_USER_INFO=true
# PASSWORD_MAX_CONSECUTIVE_REPEATS=3
# PASSWORD_HISTORY_COUNT=0

# ============================================================================
# TELEGRAM BOT
# ============================================================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://api.yourdomain.com/telegram-bot/webhook
# Secret token for validating webhook requests from Telegram
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# Separate bot for customer-facing features (optional)
# TELEGRAM_CUSTOMER_BOT_TOKEN=
# Set to 'true' to disable bot polling (use webhooks instead)
# DISABLE_BOT_POLLING=false

# ============================================================================
# SMS PROVIDERS (Uzbekistan)
# ============================================================================
# Eskiz (https://eskiz.uz)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# ESKIZ_SENDER_ID=4546

# PlayMobile (https://playmobile.uz)
# PLAYMOBILE_LOGIN=
# PLAYMOBILE_PASSWORD=
# PLAYMOBILE_SENDER_ID=

# ============================================================================
# EMAIL (SMTP)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="VendHub OS <noreply@vendhub.uz>"
# SMTP_FROM_NAME=VendHub

# ============================================================================
# STORAGE (MinIO/S3/Supabase Storage)
# ============================================================================
# Primary naming: STORAGE_*
# AWS_* vars are supported as fallbacks for AWS-native deployments
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=vendhub
STORAGE_REGION=uz-tashkent-1
# STORAGE_PUBLIC_URL=https://cdn.vendhub.uz
# STORAGE_FORCE_PATH_STYLE=true

# MinIO Console
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================================
# PAYMENT INTEGRATIONS (Uzbekistan)
# ============================================================================

# Payme (https://payme.uz)
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_MODE=true
# PAYME_BASE_URL=https://checkout.paycom.uz/api
# PAYME_CALLBACK_URL=

# Click (https://click.uz)
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
# CLICK_BASE_URL=https://my.click.uz/services/pay
# CLICK_RETURN_URL=

# Uzum Bank (https://uzumbank.uz)
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
# UZUM_API_URL=https://api.uzum.uz
# UZUM_RETURN_URL=

# Telegram Payments (provider tokens for in-bot payments)
# TELEGRAM_PAYMENT_PAYME_TOKEN=
# TELEGRAM_PAYMENT_CLICK_TOKEN=
# TELEGRAM_PAYMENT_UZUM_TOKEN=
# TELEGRAM_PAYMENT_STRIPE_TOKEN=

# ============================================================================
# MAPS
# ============================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# YANDEX_MAPS_API_KEY=

# ============================================================================
# WEB PUSH NOTIFICATIONS (VAPID)
# ============================================================================
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT_EMAIL=mailto:admin@vendhub.uz

# ============================================================================
# FIREBASE CLOUD MESSAGING (Mobile Push)
# ============================================================================
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# Or provide the entire service account JSON (base64-encoded):
# FIREBASE_SERVICE_ACCOUNT_KEY=

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=
SENTRY_DEV_ENABLED=false
LOG_LEVEL=debug
LOG_FORMAT=combined
# APP_VERSION=1.0.0

# Prometheus metrics token (protects /metrics endpoint for Grafana scraping)
# METRICS_TOKEN=
# Monitoring API key (protects /monitoring/metrics endpoint)
METRICS_API_KEY=changeme_metrics_key_min_32_chars

# Agent Bridge write key (required to protect /agent-bridge write endpoints)
AGENT_API_KEY=changeme_agent_key_min_32_chars

# Grafana (used by docker-compose.monitoring.yml)
# IMPORTANT: Change these in production! Generate with: openssl rand -base64 24
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ============================================================================
# AI INTEGRATION (OpenAI / Anthropic)
# ============================================================================
# For AI Import, Anomaly Detection, Smart Suggestions
AI_PROVIDER=openai
# AI_PROVIDER=anthropic

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_TELEGRAM_BOT=true
FEATURE_SMS_NOTIFICATIONS=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_PAYMENT_INTEGRATION=true
FEATURE_AI_IMPORT=true
FEATURE_AI_ANALYSIS=true

# ============================================================================
# RATE LIMITING
# ============================================================================
# Max requests per 60-second window (per user)
THROTTLE_LIMIT=100

# ============================================================================
# MULTI-TENANT
# ============================================================================
DEFAULT_ORGANIZATION_ID=default

# ============================================================================
# AGENT MODE (dev/testing only — bypasses auth, NEVER in production)
# ============================================================================
# AGENT_MODE=true
# AGENT_USER_EMAIL=agent@vendhub.test
# AGENT_USER_ROLE=owner
# AGENT_ORG_ID=00000000-0000-0000-0000-000000000001

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================
# Slack notifications
# SLACK_WEBHOOK_URL=
# WhatsApp Business API
# WHATSAPP_API_URL=
# WHATSAPP_ACCESS_TOKEN=

# ============================================================================
# DOCKER PROFILES
# ============================================================================
# Use 'dev' for development tools (adminer, redis-commander, bull-board)
# Use 'production' for nginx, certbot
# COMPOSE_PROFILES=dev

# ============================================================================
# BACKUP (Optional)
# ============================================================================
BACKUP_ENABLED=false
BACKUP_CRON="0 2 * * *"
BACKUP_S3_BUCKET=vendhub-backups
BACKUP_RETENTION_DAYS=30

# ============================================================================
# OpenTelemetry Tracing
# ============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=vendhub-api
OTEL_COLLECTOR_ENDPOINT=http://localhost:4318/v1/traces
