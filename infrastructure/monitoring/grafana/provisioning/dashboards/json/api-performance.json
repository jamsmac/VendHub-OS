{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{app=\"vendhub-api\"}[5m])) by (method)",
          "legendFormat": "{{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app=\"vendhub-api\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"vendhub-api\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app=\"vendhub-api\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{app=\"vendhub-api\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors/s"
        },
        {
          "expr": "sum(rate(http_requests_total{app=\"vendhub-api\",status=~\"4..\"}[5m]))",
          "legendFormat": "4xx errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(http_active_connections{app=\"vendhub-api\"})",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "process_uptime_seconds{app=\"vendhub-api\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{app=\"vendhub-api\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{app=\"vendhub-api\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{app=\"vendhub-api\"}",
          "legendFormat": "Heap Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{app=\"vendhub-api\"}[5m]) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100 }
      }
    },
    {
      "title": "Slowest Endpoints (p95)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"vendhub-api\"}[5m])) by (le, route)))",
          "legendFormat": "{{route}}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vendhub", "api", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "VendHub API Performance",
  "uid": "vendhub-api-performance"
}
