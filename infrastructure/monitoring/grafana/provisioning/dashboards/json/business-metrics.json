{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Orders / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(vendhub_orders_total[1h])) * 3600",
          "legendFormat": "Orders/hour"
        }
      ]
    },
    {
      "title": "Revenue (UZS / hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(vendhub_revenue_uzs_total[1h])) * 3600",
          "legendFormat": "Revenue UZS/hour"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUZS" }
      }
    },
    {
      "title": "Active Machines",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "vendhub_machines_online_total",
          "legendFormat": "Online"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Offline Machines",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "vendhub_machines_offline_total",
          "legendFormat": "Offline"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Payment Methods Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(vendhub_payments_total) by (method)",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "title": "Low Inventory Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "vendhub_inventory_level{level=\"low\"}",
          "legendFormat": "{{machine_id}} - {{product}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Transaction Success Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(vendhub_transactions_successful_total) / sum(vendhub_transactions_total) * 100",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["vendhub", "business", "metrics"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "VendHub Business Metrics",
  "uid": "vendhub-business-metrics"
}
