{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Active Connections",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"vendhub\"}",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 300,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 250 }
            ]
          }
        }
      }
    },
    {
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"vendhub\"}",
          "legendFormat": "Size"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Transactions / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"vendhub\"}[5m])",
          "legendFormat": "Commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"vendhub\"}[5m])",
          "legendFormat": "Rollbacks/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"vendhub\"} / (pg_stat_database_blks_hit{datname=\"vendhub\"} + pg_stat_database_blks_read{datname=\"vendhub\"}) * 100",
          "legendFormat": "Hit Ratio %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Rows Fetched / Returned",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{datname=\"vendhub\"}[5m])",
          "legendFormat": "Rows Fetched/s"
        },
        {
          "expr": "rate(pg_stat_database_tup_returned{datname=\"vendhub\"}[5m])",
          "legendFormat": "Rows Returned/s"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"vendhub\"}[5m])",
          "legendFormat": "Inserts/s"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"vendhub\"}[5m])",
          "legendFormat": "Updates/s"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"vendhub\"}[5m])",
          "legendFormat": "Deletes/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks{datname=\"vendhub\"}[5m])",
          "legendFormat": "Deadlocks/s"
        }
      ]
    },
    {
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "pg_replication_lag",
          "legendFormat": "Lag (bytes)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Slowest Queries (pg_stat_statements)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, pg_stat_statements_mean_time_seconds)",
          "legendFormat": "{{query}}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vendhub", "postgresql", "database"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "VendHub PostgreSQL",
  "uid": "vendhub-postgresql"
}
