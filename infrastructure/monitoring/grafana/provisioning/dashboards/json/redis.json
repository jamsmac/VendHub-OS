{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "max": 1073741824,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 750000000 },
              { "color": "red", "value": 950000000 }
            ]
          }
        }
      }
    },
    {
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients"
        }
      ]
    },
    {
      "title": "Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total) * 100",
          "legendFormat": "Hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Commands / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[5m])",
          "legendFormat": "Commands/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Keys by DB",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "redis_db_keys",
          "legendFormat": "db{{db}}"
        }
      ]
    },
    {
      "title": "Evicted Keys",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total[5m])",
          "legendFormat": "Evictions/s"
        },
        {
          "expr": "rate(redis_expired_keys_total[5m])",
          "legendFormat": "Expirations/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total[5m])",
          "legendFormat": "Input"
        },
        {
          "expr": "rate(redis_net_output_bytes_total[5m])",
          "legendFormat": "Output"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Slow Log Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "redis_slowlog_length",
          "legendFormat": "Slow queries"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "redis_uptime_in_seconds",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "AOF / RDB Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "redis_rdb_last_save_timestamp_seconds",
          "legendFormat": "Last RDB Save"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "dateTimeAsIso" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vendhub", "redis", "cache"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "VendHub Redis",
  "uid": "vendhub-redis"
}
